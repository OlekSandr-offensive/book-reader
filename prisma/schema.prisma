generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int             @id @default(autoincrement())
  name         String
  email        String          @unique
  password     String
  refreshToken String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  books        Book[]
  progress     DailyProgress[]
  trainings    Training[]
}

model Book {
  id         Int             @id @default(autoincrement())
  title      String
  author     String
  year       Int
  totalPages Int
  status     BookStatus      @default(PLAN)
  rating     Float?
  resume     String?
  userId     Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress   DailyProgress[]
  trainings  TrainingBook[]

  @@unique([userId, title, author])
  @@index([userId])
  @@index([status])
}

model Training {
  id           Int             @id @default(autoincrement())
  userId       Int
  startDate    DateTime
  finishDate   DateTime
  durationDays Int
  status       TrainingStatus  @default(IN_PROGRESS)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  progress     DailyProgress[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  books        TrainingBook[]

  @@index([userId])
  @@index([status])
}

model TrainingBook {
  id            Int      @id @default(autoincrement())
  trainingId    Int
  bookId        Int
  isFinished    Boolean  @default(false)
  countReadPage Int      @default(0)
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  training      Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([trainingId, bookId])
  @@index([trainingId])
  @@index([bookId])
}

model DailyProgress {
  id         Int      @id @default(autoincrement())
  userId     Int
  trainingId Int
  bookId     Int
  date       DateTime
  pagesRead  Int
  createdAt  DateTime @default(now())
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trainingId])
  @@index([bookId])
  @@index([date])
}

enum BookStatus {
  PLAN
  READING
  DONE
}

enum TrainingStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}
